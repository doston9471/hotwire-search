<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Hotwire Search</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Instant Hotwire search with infinite scroll.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <main class="shell">
      <%= yield %>
    </main>
  </body>
</html>
